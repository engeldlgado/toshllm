+    tq3_rht_inverse(buf);
+
+    float4x4 reg_f;
+    for (int i = 0; i < 4; i++) {
+        for (int k = 0; k < 4; k++) {
+            reg_f[i][k] = buf[il * 16 + i * 4 + k];
+        }
+    }
+    reg = (type4x4) reg_f;
