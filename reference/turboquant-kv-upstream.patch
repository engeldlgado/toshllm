+        float(turbo_centroids_2bit_h[(qb      ) & 0x03]) * norm,
+        float(turbo_centroids_2bit_h[(qb >> 2) & 0x03]) * norm,
+        float(turbo_centroids_2bit_h[(qb >> 4) & 0x03]) * norm,
+        float(turbo_centroids_2bit_h[(qb >> 6)       ]) * norm
+    ));
