-        tmp = ggml_mul_mat_aux(ctx, tmp, rot);
+        // rotate back. `rot` (k_rot) only exists for the TurboQuant K-rotation
+        // scheme; it is null for a standard quantized KV cache (q8_0/q4_0), where
+        // we use the plain dequant->RoPE->requant path. Without this guard, a KV
+        // shift (cache-reuse / context-shift) on a standard quantized cache
+        // dereferenced a null tensor and crashed.
+        if (rot) tmp = ggml_mul_mat_aux(ctx, tmp, rot);
 
         tmp = ggml_rope_ext(ctx, tmp,
                 shift, factors, n_rot, rope_type, n_ctx_orig, freq_base, freq_scale,
                 yarn_ext_factor, yarn_attn_factor, yarn_beta_fast, yarn_beta_slow);
 
         // rotate fwd
-        tmp = ggml_mul_mat_aux(ctx, tmp, rot);
+        if (rot) tmp = ggml_mul_mat_aux(ctx, tmp, rot);
 
         tmp = ggml_cpy(ctx, tmp, cur);
     } else {
