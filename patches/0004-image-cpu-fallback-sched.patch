+    bool graph_needs_cpu_fallback(ggml_cgraph* gf) {
+        if (runtime_backend == nullptr || sd_backend_is_cpu(runtime_backend)) {
+            return false;
+        }
+        // Escape hatch for a wave64 card that miscomputes an op supports_op accepts.
+        static const bool forced = getenv("SD_TOSH_CPU_FALLBACK") != nullptr;
+        if (forced) {
+            return true;
+        }
+        const int n_nodes = ggml_graph_n_nodes(gf);
+        for (int i = 0; i < n_nodes; ++i) {
+            ggml_tensor* node = ggml_graph_node(gf, i);
+            if (node == nullptr || node->op == GGML_OP_NONE || ggml_is_empty(node)) {
+                continue;
+            }
+            if (!ggml_backend_supports_op(runtime_backend, node)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    bool ensure_fallback_sched(size_t graph_size) {
+        if (fallback_sched != nullptr && fallback_sched_size >= graph_size) {
+            return true;
+        }
+        if (fallback_sched != nullptr) {
+            ggml_backend_sched_free(fallback_sched);
+            fallback_sched = nullptr;
+        }
+        if (fallback_cpu_backend == nullptr) {
+            fallback_cpu_backend = sd_backend_cpu_init();
+        }
+        if (fallback_cpu_backend == nullptr) {
+            return false;
+        }
+        ggml_backend_t backends[2] = {runtime_backend, fallback_cpu_backend};
+        fallback_sched      = ggml_backend_sched_new(backends, nullptr, 2, graph_size, false, true);
+        fallback_sched_size = graph_size;
+        return fallback_sched != nullptr;
+    }
