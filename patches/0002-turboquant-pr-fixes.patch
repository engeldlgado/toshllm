+static const char * ggml_metal_fa_amd_type_suffix(enum ggml_type t) {
+    switch (t) {
+        case GGML_TYPE_F16:      return "f16";
+        case GGML_TYPE_Q8_0:     return "q8_0";
+        case GGML_TYPE_Q4_0:     return "q4_0";
