+// Dedicated flash-attention DECODE kernel for AMD discrete GPUs. The templated
+// vec kernel above miscompiles on these GPUs (the SIMD primitives are correct in
+// isolation, but the full kernel produces garbage). This minimal version was
+// validated against a CPU reference and handles the common decode case only:
+// head_dim 128, f16 K/V, additive mask, GQA, scale; no ALiBi/softcap/sinks.
+// NSG simdgroups per (query, head, batch) threadgroup split the KV cache between
+// them (strided), then simdgroup 0 merges the partial results with the online-softmax
+// combine. NWG = 1 (no split-K across workgroups). Keep NSG in sync with the host.
+// Dedicated AMD decode (vec) flash-attention kernel. The upstream templated vec
+// kernel miscompiles on RDNA 2 under Metal; this from-scratch version keeps a
+// simple structure (one float4 per lane over the 128-dim head, NSG simdgroups
+// splitting the KV stream + online-softmax merge) that computes correctly.
+//
+// Generalized over the K/V cache element type via the existing dequantize_*_t4
+// helpers (same convention as the upstream vec kernel): each lane owns the 4
+// contiguous head elements [tiisg*4 .. tiisg*4+3]. With NK = QK/4 dequant chunks
+// per block, lane tiisg reads block (tiisg/NK), sub-chunk (tiisg%NK). NK is 1 for
+// f16, 8 for q8_0/q4_0 (block 32), 32 for turbo2/3/4 (block 128). Q is always f32.
+// DK = head dim (128 or 256). Each lane owns NC = DK/128 float4 chunks of the head:
+// chunk c on lane tiisg covers head elements [(tiisg + c*32)*4 .. +3]. NK = QK/4 dequant
+// chunks per block, so chunk index ch reads block (ch/NK), sub-chunk (ch%NK).
+template<
+    short DK, short NSG,
+    typename k_t, short NKK, void (*deq_k)(device const k_t *, short, thread float4 &),
+    typename v_t, short NKV, void (*deq_v)(device const v_t *, short, thread float4 &)>
+kernel void kernel_flash_attn_ext_vec_amd(
+        constant ggml_metal_kargs_flash_attn_ext_vec & args [[buffer(0)]],
+        device const char * q     [[buffer(1)]],
+        device const char * k     [[buffer(2)]],
+        device const char * v     [[buffer(3)]],
+        device const char * mask  [[buffer(4)]],
+        device const char * sinks [[buffer(5)]],
+        device const char * pad   [[buffer(6)]],
+        device       char * dst   [[buffer(7)]],
+        uint3  tgpig [[threadgroup_position_in_grid]],
+        ushort tiisg [[thread_index_in_simdgroup]],
+        ushort sgitg [[simdgroup_index_in_threadgroup]]) {
+    constexpr short DV4 = DK/4;   // float4 per head row (32 for DK=128, 64 for DK=256)
+    constexpr short NC  = DV4/32; // float4 chunks each lane owns (1 for DK=128, 2 for DK=256)
+    // NSG (simdgroups per threadgroup) is a template parameter, kept in sync with
+    // the host dispatch. More simdgroups split the KV stream into shorter serial
+    // loops, which is a large decode win at depth; it is chosen per head dim so
+    // the sh_acc threadgroup buffer (NSG*DV4 float4) stays at 16 KiB: 32 for
+    // DK=128, 16 for DK=256.
+
+    threadgroup float4 sh_acc[NSG*DV4]; // per-simdgroup partial output (NC float4 per lane)
+    threadgroup float  sh_m[NSG];       // per-simdgroup running max
+    threadgroup float  sh_s[NSG];       // per-simdgroup running sum
+
+    const int iq1 = tgpig[0]; // query token
+    const int iq2 = tgpig[1]; // query head
+    const int iq3 = tgpig[2]; // batch
+
+    device const float4 * q4 = (device const float4 *) (q + iq1*args.nb01 + iq2*args.nb02 + iq3*args.nb03);
+
+    // grouped-query attention: map query head -> kv head
+    const int ikv2 = iq2 / (args.ne02 / args.ne_12_2);
+    const int ikv3 = iq3 / (args.ne03 / args.ne_12_3);
+
+    device const char * kp = k + ikv2*args.nb12 + ikv3*args.nb13;
+    device const char * vp = v + ikv2*args.nb22 + ikv3*args.nb23;
+
+    device const half * pm = (device const half *) (mask + iq1*args.nb31 + (iq2%args.ne32)*args.nb32 + (iq3%args.ne33)*args.nb33);
+
+    float4 myq[NC];  // this lane's slice(s) of the query
+    for (short c = 0; c < NC; ++c) {
+        myq[c] = q4[tiisg + c*32];
+    }
+
+    float4 acc[NC];  // this lane's slice(s) of the output
+    for (short c = 0; c < NC; ++c) {
+        acc[c] = float4(0.0f);
+    }
+    float m = -FLT_MAX/2;
+    float s = 0.0f;
+
+    for (int j = sgitg; j < args.ne11; j += NSG) {
+        const float mv = (float) pm[j];
+        if (mv <= -1e30f) {
+            continue;
+        }
+
+        device const k_t * kb = (device const k_t *) (kp + (uint64_t) j*args.nb11);
+        float pl = 0.0f;
+        for (short c = 0; c < NC; ++c) {
+            const short ch = tiisg + c*32;
+            float4 kreg;
+            deq_k(kb + ch/NKK, ch%NKK, kreg);
+            pl += dot(myq[c], kreg);
+        }
+        const float p = simd_sum(pl); // full DK-dim Q.K
+
+        const float pp   = p*args.scale + mv;
+        const float nm   = max(m, pp);
+        const float corr = exp(m  - nm);
+        const float w    = exp(pp - nm);
+
+        device const v_t * vb = (device const v_t *) (vp + (uint64_t) j*args.nb21);
+        for (short c = 0; c < NC; ++c) {
+            const short ch = tiisg + c*32;
+            float4 vreg;
+            deq_v(vb + ch/NKV, ch%NKV, vreg);
+            acc[c] = acc[c]*corr + w*vreg;
+        }
+        s = s*corr + w;
+        m = nm;
+    }
+
+    // publish this simdgroup's partials (acc, m, s) and merge in simdgroup 0
+    for (short c = 0; c < NC; ++c) {
+        sh_acc[sgitg*DV4 + tiisg + c*32] = acc[c];
+    }
+    if (tiisg == 0) {
+        sh_m[sgitg] = m;
+        sh_s[sgitg] = s;
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    if (sgitg == 0) {
+        float gm = -FLT_MAX/2;
+        for (short g = 0; g < NSG; ++g) {
+            gm = max(gm, sh_m[g]);
+        }
+        float4 num[NC];
+        for (short c = 0; c < NC; ++c) {
+            num[c] = float4(0.0f);
+        }
+        float den = 0.0f;
+        for (short g = 0; g < NSG; ++g) {
+            const float f = exp(sh_m[g] - gm);
+            for (short c = 0; c < NC; ++c) {
+                num[c] += f * sh_acc[g*DV4 + tiisg + c*32];
+            }
+            den += f * sh_s[g];
+        }
+        const float inv = den > 0.0f ? 1.0f/den : 0.0f;
+
+        const int64_t rid = (int64_t) iq3*args.ne2*args.ne1 + iq2 + (int64_t) iq1*args.ne1;
+        device float4 * dst4 = (device float4 *) dst;
+        for (short c = 0; c < NC; ++c) {
+            dst4[rid*DV4 + tiisg + c*32] = num[c]*inv;
+        }
+    }
+}
+
+typedef decltype(kernel_flash_attn_ext_vec_amd<128, 32, half4, 1, dequantize_f16_t4, half4, 1, dequantize_f16_t4>) flash_attn_ext_vec_amd_t;
+
